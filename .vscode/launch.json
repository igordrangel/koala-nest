  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "NestJS Debug",
      "program": "${workspaceFolder}/libs/koala-nest/node_modules/@nestjs/cli/bin/nest.js",
      "cwd": "${workspaceFolder}/libs/koala-nest",
      "args": [
        "start",
        "--watch"
      ],
      "autoAttachChildProcesses": true,
      "restart": true,
      "console": "integratedTerminal"
    },
  ]
}